
{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Dados cadastrais de um integrante do efetivo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "qra": { "type": "string" },
        "matricula": { "type": "string" },
        "validationCode": { "type": "string", "description": "Código de ativação do agente." },
        "escala": { "type": "string" },
        "turno": { "type": "string" },
        "role": { "type": "string" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDENTE", "ATIVO", "FÉRIAS", "LICENÇA", "INATIVO"] },
        "avatar": { "type": "string" },
        "admissionDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" }
      },
      "required": ["name", "qra", "role", "status", "matricula", "escala", "turno", "unit"]
    },
    "Request": {
      "title": "Operational Request",
      "description": "Solicitação operacional enviada por um funcionário (férias, permuta, etc).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "type": { "type": "string", "enum": ["vacation", "leave", "exchange", "other"] },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Pendente", "Aprovado", "Negado", "Em Revisão"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employeeId", "type", "status"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Definição de escalas de serviço.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Definição de turnos de trabalho.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Role": {
      "title": "Role",
      "description": "Cargos e funções na unidade.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "LaunchType": {
      "title": "Launch Type",
      "description": "Tipos de lançamento para banco de horas.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "TimeBankEntry": {
      "title": "Time Bank Entry",
      "description": "Registro de horas extras ou compensações.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["Extra", "Compensação"] },
        "hours": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["employeeId", "date", "type", "hours"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "#/backend/entities/Employee",
      "description": "Coleção de funcionários da unidade."
    },
    "/requests/{requestId}": {
      "schema": "#/backend/entities/Request",
      "description": "Coleção global de solicitações operacionais."
    },
    "/schedules/{scheduleId}": {
      "schema": "#/backend/entities/Schedule",
      "description": "Coleção de escalas configuradas."
    },
    "/shifts/{shiftId}": {
      "schema": "#/backend/entities/Shift",
      "description": "Coleção de turnos configurados."
    },
    "/roles/{roleId}": {
      "schema": "#/backend/entities/Role",
      "description": "Coleção de cargos configurados."
    },
    "/launchTypes/{launchTypeId}": {
      "schema": "#/backend/entities/LaunchType",
      "description": "Coleção de tipos de lançamento configurados."
    },
    "/employees/{employeeId}/timeBank/{entryId}": {
      "schema": "#/backend/entities/TimeBankEntry",
      "description": "Sub-coleção com o histórico de banco de horas por funcionário."
    }
  }
}
